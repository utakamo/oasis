#!/usr/bin/env lua

-- olt: Oasis Local Tool
local common        = require("oasis.common")
local misc          = require("oasis.chat.misc")
local olt_client    = require("oasis.local.tool.client")
local uci           = require("luci.model.uci").cursor()

-- Some Oasis-managed tools may exceed the default 30-second timeout.
-- In those cases, requests can be terminated before the tool finishes,
-- especially when package downloads or installs are involved.
-- Keep the minimum at 60 seconds to avoid premature timeouts.
local MIN_TIMEOUT = 60

local function ensure_min_timeout(config, section, option, min_timeout)
    local current_timeout = uci:get(config, section, option) or ""
    local numeric_timeout = tonumber(current_timeout)
    if (not numeric_timeout) or (numeric_timeout < min_timeout) then
        uci:set(config, section, option, tostring(min_timeout))
        return true
    end

    return false
end

local function ensure_runtime_prerequisites(min_timeout)
    -- Oasis assumes that the common usage is AI interaction via LuCI.
    -- Users chat with AI through the LuCI UI, and the AI may execute tools.
    -- Some tools (e.g., downloading external data over the network) may take time.
    -- To handle such cases, Oasis applies the following timeout settings.
    if misc.check_file_exist("/etc/config/uhttpd") then
        local changed = false
        if ensure_min_timeout("uhttpd", "main", "network_timeout", min_timeout) then
            changed = true
        end
        if ensure_min_timeout("uhttpd", "main", "script_timeout", min_timeout) then
            changed = true
        end
        if changed then
            uci:commit("uhttpd")
        end
    end

    if misc.check_file_exist("/etc/config/rpcd") then
        if ensure_min_timeout("rpcd", "@rpcd[0]", "timeout", min_timeout) then
            uci:commit("rpcd")
        end
    end
end

local function refresh_local_tool_registry()
    local ok, err = olt_client.update_server_info()
    if not ok then
        return false, err or "Failed to refresh local tool registry"
    end

    return true
end

local function rebuild_manifest_store()
    local ok, err = olt_client.rebuild_manifest_store()
    if not ok then
        return false, err or "Failed to rebuild manifest store"
    end

    return true
end

local function run_setup()
    ensure_runtime_prerequisites(MIN_TIMEOUT)

    local ok, err = refresh_local_tool_registry()
    if not ok then
        io.stderr:write(err .. "\n")
        os.exit(1)
    end
end

if arg[1] == "init" then
    run_setup()
elseif arg[1] == "refresh" then
    run_setup()
elseif arg[1] == "rebuild-manifest" then
    local ok, err = rebuild_manifest_store()
    if not ok then
        io.stderr:write(err .. "\n")
        os.exit(1)
    end
elseif arg[1] == "delete" then
    uci:set(common.db.uci.cfg, common.db.uci.sect.support, "local_tool", "0")
    uci:set(common.db.uci.cfg, common.db.uci.sect.support, "remote_mcp_server", "0")
    uci:delete_all(common.db.uci.cfg, common.db.uci.sect.tool)
    uci:commit(common.db.uci.cfg)
end
