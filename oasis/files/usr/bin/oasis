#!/usr/bin/env lua

local common = require("oasis.common")
local console = require("oasis.console")
local uci = require("luci.model.uci").cursor()
local main_cmd = arg[1]

local unload_targets = {
    { name = "oasis", path = common.flag.unload.oasis },
    { name = "oasis-mod-tool", path = common.flag.unload.oasis_mod_tool },
    { name = "oasis-mod-spring", path = common.flag.unload.oasis_mod_spring },
}

local function print_restart_guide()
    print([=[
============================================================
                    REBOOT REQUIRED
============================================================
Oasis or plugin module has been installed.

please choose one of the following options:
1. Reboot OpenWrt:
        root@OpenWrt:~# reboot
2. Restart rpcd service:
        root@OpenWrt:~# service rpcd restart

============================================================
    ]=])
end

local function collect_unloaded_targets()
    local targets = {}
    for _, target in ipairs(unload_targets) do
        if common.check_unloaded_plugin(target.name) then
            table.insert(targets, target)
        end
    end
    return targets
end

local function clear_unloaded_targets(targets)
    for _, target in ipairs(targets) do
        os.remove(target.path)
    end
end

local function handle_unloaded_targets()
    local targets = collect_unloaded_targets()
    if #targets == 0 then
        return false
    end

    if common.check_unloaded_plugin("oasis") then
        print("\27[31mOasis has been installed. A reboot or rpcd restart is required to use it.\27[0m")
    end

    if common.check_unloaded_plugin("oasis-mod-tool") or common.check_unloaded_plugin("oasis-mod-spring") then
        print("\27[31mInstalled plugin modules have been detected.\27[0m")
        print("\27[31mA reboot or rpcd restart is required to use them.\27[0m")
    end

    print()

    console.write("Reboot OpenWrt now [Y/N]: ")
    console.flush()

    local reply = (console.read() or ""):upper()
    if reply == "Y" then
        clear_unloaded_targets(targets)
        console.print("\nSystem reboot will start in 3 seconds.\n")
        os.execute("(sleep 3 && reboot) >/dev/null 2>&1 &")
        return true
    end

    console.write("Restart rpcd service now [Y/N]: ")
    console.flush()

    reply = (console.read() or ""):upper()
    if reply == "Y" then
        clear_unloaded_targets(targets)
        console.print("\nrpcd restart will start in 3 seconds.\n")
        os.execute("(sleep 3 && /etc/init.d/rpcd restart) >/dev/null 2>&1 &")
        return true
    end

    print_restart_guide()
    return true
end

if main_cmd ~= "manifest" then
    if handle_unloaded_targets() then
        return
    end

    if not common.check_prepare_oasis() then
        print_restart_guide()
        return
    end
end

local oasis
if main_cmd ~= "manifest" then
    oasis = require("oasis.chat.main")
end

local options_spec = {
    ["-n"] = "n",
    ["-u"] = "u",
    ["-k"] = "k",
    ["-m"] = "m",
    ["-s"] = "s"
}

local function banner()
    local cyan = "\27[36m"
    local reset = "\27[0m"

    print(cyan ..
    "┏━━┓  ┏━━┓  ┏━━┓  ┏━━┓  ┏━━┓\n" ..
    "┃┏┓┃  ┃┏┓┃  ┃┏━┛  ┗┓┏┛  ┃┏━┛\n" ..
    "┃┃┃┃  ┃┗┛┃  ┃┗━┓   ┃┃   ┃┗━┓\n" ..
    "┃┗┛┃  ┃┏┓┃  ┏━┛┃  ┏┛┗┓  ┏━┛┃\n" ..
    "┗━━┛  ┗┛┗┛  ┗━━┛  ┗━━┛  ┗━━┛\n" ..
    reset ..
    "-------------------------------------------\n" ..
    "Oasis 3.2.6\n" ..
    "-------------------------------------------"
    )
end

local function is_local_tool_supported()
    return uci:get_bool(common.db.uci.cfg, common.db.uci.sect.support, "local_tool")
end

-- Print CLI help text.
-- @return nil
local function help()
    local lines = {
        "Usage: oasis <command> [[<options>] arguments]...",
        "",
        "Options:",
        " -u <Endpoint>          Set the  AI Service Endpoint(URL)",
        " -k <api-key>           Set the API key",
        " -m <model>             Set the LLM model",
        " -p <storage>           Set the storage path",
        " -s <sysmsg key>        Select the system message key  (for sysmsg command)",
        " -c <system message>    Create new system message data (for sysmsg command)",
        "",
        "Commands:",
        " storage <path> [<chat-max>]",
        " add [<service> [<endpoint> [<api-key> [<model> [<storage>]]]]]",
        " change [no=<service-number> [<options> <value>]...]",
        " select [no=<service-number>]",
        " delete no=<service-number>",
        " chat [no=<chat-number>]",
        " prompt <message>",
        " agent [-t <turns>] <goal>",
        " sysmsg [chat|prompt <option> <value>]",
        " delchat no=<chat-number>",
        " rename no=<chat-number> <title>",
        " list",
        " tools",
        " manifest build [<script_path>]",
        " manifest apply [--yes|-y] [<manifest_path>]",
    }

    lines[#lines + 1] = ""
    lines[#lines + 1] = "Docs:"
    lines[#lines + 1] = " https://github.com/utakamo/oasis"

    console.print(banner())
    console.print(table.concat(lines, "\n"))
end

-- Parse key-value style options starting from index.
-- @param args table argv
-- @param start_index integer
-- @return table options
local function parse_options(args, start_index)
    local options = {}
    local i = start_index
    while i <= #args do
        local opt_key = args[i]
        local opt_val = args[i + 1]
        local opt_name = options_spec[opt_key]
        if opt_name and opt_val then
            options[opt_name] = opt_val
            i = i + 2
        else
            i = i + 1
        end
    end
    return options
end

local function parse_manifest_args(args, start_index)
    local result = {
        action = nil,
        target = nil,
        assume_yes = false,
    }

    for i = start_index, #args do
        local token = args[i]
        if token == "--yes" or token == "-y" then
            result.assume_yes = true
        elseif token == "build" or token == "apply" then
            if result.action and result.action ~= token then
                return nil, "too many manifest subcommands"
            end
            result.action = token
        elseif token and token:sub(1, 1) == "-" then
            return nil, "unknown option: " .. token
        elseif not result.target then
            result.target = token
        else
            return nil, "too many arguments for manifest command"
        end
    end

    if result.assume_yes and result.action ~= "apply" then
        return nil, "--yes is only supported with manifest apply"
    end

    return result, nil
end

-- Extract numeric value from a token like "no=3".
-- @param arg_str string
-- @return string|nil
local function extract_no(arg_str)
    local prefix = "no="
    if arg_str and arg_str:sub(1, #prefix) == prefix then
        return arg_str:sub(#prefix + 1)
    end
    return nil
end

local commands = {}

commands.storage = function(args)
    oasis.storage({ path = args[2], chat_max = args[3] })
end

commands.add = function(args)
    oasis.add({
        service  = args[2],
        endpoint = args[3],
        api_key  = args[4],
        model    = args[5],
    })
end

commands.change = function(args)

    local no = extract_no(args[2])

    if no then
        local options = parse_options(args, 3)
        oasis.change({ no = no }, options)
    else
        oasis.show_service_list()
    end
end

commands.select = function(args)

    local no = extract_no(args[2])

    if no then
        oasis.select({ no = no })
    else
        oasis.show_service_list()
    end
end

commands.delete = function(args)

    local no = extract_no(args[2])

    if no then
        oasis.delete({ no = no })
    else
        oasis.show_service_list()
    end
end

commands.chat = function(args)
    local no = extract_no(args[2])
    oasis.chat({ no = no })
end

commands.delchat = function(args)
    local no = extract_no(args[2])
    if no then
        oasis.delchat({ no = no })
    else
        oasis.list()
    end
end

commands.prompt = function(args)
    if args[2] then
        local message = table.concat(args, " ", 2)
        oasis.prompt({ message = message })
    else
        help()
    end
end

commands.agent = function(args)
    local ok, agent = pcall(require, "oasis.agent.main")
    if not ok or (type(agent) ~= "table") or (not agent.run) then
        print("This command requires oasis-mod-agent. Please install oasis-mod-agent first.")
        return
    end

    agent.run(args)
end

commands.sysmsg = function(args)
    local option = args[3]
    local param  = args[4]

    if option == "-c" and args[4] then
        param = table.concat(args, " ", 4)
    end

    oasis.sysmsg({
        cmd    = args[2],
        option = option,
        param  = param
    })
end

commands.rename = function(args)
    local no = extract_no(args[2])
    if no and args[3] then
        oasis.rename({ no = no, title = args[3] })
    else
        oasis.list()
    end
end

commands.list = function()
    oasis.list()
end

commands.tools = function()
    oasis.tools()
end

-- TODO: extend manifest subcommands to support:
--   oasis manifest build <script-path> <output-path>
--   oasis manifest build-all
commands.manifest = function(args)
    if not is_local_tool_supported() then
        print("This command is exclusive to oasis-mod-tool.")
        print("Please install oasis-mod-tool to use it.")
        return
    end

    local client = require("oasis.local.tool.client")
    local manifest_args, parse_err = parse_manifest_args(args, 2)
    if not manifest_args then
        io.stderr:write(parse_err .. "\n")
        os.exit(1)
    end

    local action = manifest_args.action
    local script_path = manifest_args.target

    if not action then
        if script_path then
            local manifest_ok, manifest_or_err = client.build_manifest_for_script(script_path)
            if not manifest_ok then
                io.stderr:write((manifest_or_err or "Failed to build manifest") .. "\n")
                os.exit(1)
            end

            local jsonc = require("luci.jsonc")
            print(jsonc.stringify(manifest_or_err, true))
            return
        end

        local targets = client.list_manifest_targets()
        if #targets == 0 then
            print("No manifest candidate scripts found.")
            return
        end

        print("Targets:")
        for _, item in ipairs(targets) do
            print(" - Script:   " .. item.script_path)
            print("   Manifest: " .. item.manifest_path)
        end
        return
    end

    if action == "apply" then
        local manifest_path = manifest_args.target
        if not manifest_path then
            if manifest_args.assume_yes then
                io.stderr:write("manifest path is required with --yes\n")
                os.exit(1)
            end
            local manifest_files = client.list_manifest_files()
            if #manifest_files == 0 then
                print("No manifest files found.")
                return
            end

            print("Manifest files:")
            for _, file in ipairs(manifest_files) do
                print(" - " .. file)
            end
            return
        end

        local plan_ok, plan_or_err = client.build_manifest_apply_plan(manifest_path)
        if not plan_ok then
            io.stderr:write((plan_or_err or "Failed to build manifest apply plan") .. "\n")
            os.exit(1)
        end

        local commands = plan_or_err.commands or {}
        if #commands == 0 then
            print("No UCI changes required.")
            return
        end

        print("The following UCI changes will be applied:")
        for _, line in ipairs(commands) do
            print(line)
        end
        print()

        if not manifest_args.assume_yes then
            console.write("Apply this manifest [Y/N]: ")
            console.flush()

            local reply = (console.read() or ""):upper()
            if reply ~= "Y" then
                print("Canceled.")
                return
            end
        else
            print("Auto-apply enabled; skipping confirmation.")
        end

        local apply_ok, apply_info_or_err = client.apply_manifest_plan(plan_or_err)
        if not apply_ok then
            io.stderr:write((apply_info_or_err or "Failed to apply manifest") .. "\n")
            os.exit(1)
        end

        print("Manifest applied.")
        return
    end

    if not script_path then
        local candidates = client.list_manifest_candidate_scripts()
        if #candidates == 0 then
            print("No manifest candidate scripts found.")
            return
        end

        print("Manifest candidate scripts:")
        for _, candidate in ipairs(candidates) do
            print(" - " .. candidate)
        end
        return
    end

    local manifest_ok, manifest_or_err = client.build_manifest_for_script(script_path)
    if not manifest_ok then
        io.stderr:write((manifest_or_err or "Failed to build manifest") .. "\n")
        os.exit(1)
    end

    local jsonc = require("luci.jsonc")
    print(jsonc.stringify(manifest_or_err, true))
end

if not main_cmd or not commands[main_cmd] then
    help()
else
    commands[main_cmd](arg)
end
